# Public ClickHouse demos used in the articles
ALTINITY_HOST=demo.demo.altinity.cloud
ALTINITY_PORT=9440
ALTINITY_USER=demo
ALTINITY_PASSWORD=demo
ALTINITY_DATABASE=default
ALTINITY_TABLE=ontime

CLICKHOUSE_INC_HOST=sql-clickhouse.clickhouse.com
CLICKHOUSE_INC_PORT=9440
CLICKHOUSE_INC_USER=demo
CLICKHOUSE_INC_PASSWORD=
CLICKHOUSE_INC_DATABASE=ontime
CLICKHOUSE_INC_TABLE=ontime

# Public Altinity MCP demo (HTTP/OpenAPI)
MCP_BASE_URL=https://mcp.demo.altinity.cloud
MCP_DEMO_TOKEN=<PUT_YOUR_JWE_TOKEN_HERE>

# Local docker-compose settings (optional)
LOCAL_MCP_PORT=8080
LOCAL_MCP_TRANSPORT=http
LOCAL_MCP_OPENAPI=http
LOCAL_MCP_LOG_LEVEL=info
